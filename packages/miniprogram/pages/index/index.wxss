/* 首页样式表 */

.index-page {
  padding-bottom: 80rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* 个人信息设置卡片 */
.profile-setup-card {
  margin-top: 20rpx;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-header {
  align-self: flex-start;
  margin-bottom: 30rpx;
}

.setup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e2a27;
}

.setup-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.avatar-nickname-box {
  width: 100%;
}

/* 微信头像容器 */
.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.02);
  border: 4rpx solid rgba(0, 150, 199, 0.3);
  box-shadow: 0 0 20rpx rgba(0, 150, 199, 0.08);
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

.avatar-wrapper::after {
  border: none; /* 移除 button 的默认边框 */
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  border-radius: 50%;
}

.placeholder-text {
  font-size: 20rpx;
  color: var(--theme-color-green);
  margin-top: 8rpx;
  font-weight: 600;
}

.avatar-hover-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.4);
  font-size: 20rpx;
}

/* 昵称输入框 */
.nickname-input {
  width: 80%;
  height: 80rpx;
  min-height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1e2a27;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  padding: 0; /* 彻底移除导致占位符和输入内容高度不一致的上下 padding */
}

.nickname-input:focus {
  border-bottom: 2rpx solid var(--theme-color-blue);
}

/* 操作选项卡片列表 */
.action-buttons-box {
  margin: 20rpx 30rpx;
}

.action-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-dark-card);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 0, 0, 0.03);
  padding: 30rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(11, 40, 34, 0.05);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.action-icon-box {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.bg-green {
  background: linear-gradient(135deg, #0b9b77 0%, #06d6a0 100%);
  box-shadow: 0 8rpx 20rpx rgba(11, 155, 119, 0.15);
}

.bg-blue {
  background: linear-gradient(135deg, #0077b6 0%, #0096c7 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 150, 199, 0.15);
}

.bg-purple {
  background: linear-gradient(135deg, #512da8 0%, #9575cd 100%);
  box-shadow: 0 8rpx 20rpx rgba(149, 117, 205, 0.15);
}

.action-text-box {
  flex: 1;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e2a27;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

/* 个人战绩大厅按钮 */
.history-entry-btn {
  margin: 40rpx auto 0;
  display: inline-flex;
  align-items: center;
  color: var(--theme-color-blue);
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(0, 150, 199, 0.06);
  border: 1px solid rgba(0, 150, 199, 0.12);
}

.entry-text {
  margin-left: 10rpx;
}

/* 弹窗核心样式 */
.join-popup-content {
  padding: 40rpx 20rpx;
  background-color: #ffffff;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e2a27;
}

.popup-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  margin-bottom: 40rpx;
}

/* 6位密码框样式 */
.code-inputs {
  width: 100%;
  justify-content: space-around;
  padding: 0 20rpx;
  position: relative;
}

.code-cell {
  width: 80rpx;
  height: 100rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.12);
  border-radius: 16rpx;
  position: relative;
  background: rgba(0, 0, 0, 0.01);
}

.code-cell.active {
  border-color: var(--theme-color-blue);
  box-shadow: 0 0 15rpx rgba(0, 150, 199, 0.2);
}

.code-char {
  font-size: 44rpx;
  font-weight: bold;
  color: #1e2a27;
}

/* 闪烁光标 */
.cursor-bar {
  width: 4rpx;
  height: 48rpx;
  background-color: var(--theme-color-blue);
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.hidden-input {
  position: absolute;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}
