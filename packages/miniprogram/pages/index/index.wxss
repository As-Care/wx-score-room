/* 首页样式表 */

.index-page {
  padding-bottom: 80rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* 个人信息设置卡片 */
.profile-setup-card {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-header {
  align-self: flex-start;
  margin-bottom: 30rpx;
}

.setup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.setup-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
}

.avatar-nickname-box {
  width: 100%;
}

/* 微信头像容器 */
.avatar-wrapper {
  padding: 0;
  width: 160rpx !important;
  height: 160rpx !important;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.05);
  border: 4rpx solid rgba(0, 180, 216, 0.4);
  box-shadow: 0 0 30rpx rgba(0, 180, 216, 0.2);
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

.avatar-wrapper::after {
  border: none; /* 移除 button 的默认边框 */
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #0b2520 0%, #154c3e 100%);
  border-radius: 50%;
}

.placeholder-text {
  font-size: 20rpx;
  color: var(--theme-color-green);
  margin-top: 8rpx;
  font-weight: 500;
}

.avatar-hover-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.5);
  font-size: 20rpx;
}

/* 昵称输入框 */
.nickname-input {
  width: 80%;
  height: 80rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.15);
  padding: 10rpx 0;
}

.nickname-input:focus {
  border-bottom: 2rpx solid var(--theme-color-blue);
}

/* 操作选项卡片列表 */
.action-buttons-box {
  margin: 20rpx 30rpx;
}

.action-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-dark-card);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.03);
  padding: 30rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.action-icon-box {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.bg-green {
  background: linear-gradient(135deg, #0f9b0f 0%, #06d6a0 100%);
  box-shadow: 0 8rpx 20rpx rgba(6, 214, 160, 0.2);
}

.bg-blue {
  background: linear-gradient(135deg, #0077b6 0%, #00b4d8 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 180, 216, 0.2);
}

.bg-purple {
  background: linear-gradient(135deg, #6200ea 0%, #bb86fc 100%);
  box-shadow: 0 8rpx 20rpx rgba(187, 134, 252, 0.2);
}

.action-text-box {
  flex: 1;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

/* 个人战绩大厅按钮 */
.history-entry-btn {
  margin: 40rpx auto 0;
  display: inline-flex;
  align-items: center;
  color: var(--theme-color-blue);
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(0, 180, 216, 0.08);
  border: 1px solid rgba(0, 180, 216, 0.15);
}

.entry-text {
  margin-left: 10rpx;
}

/* 弹窗核心样式 */
.join-popup-content {
  padding: 40rpx 20rpx;
  background-color: #0b1a16;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.popup-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
  margin-bottom: 40rpx;
}

/* 6位密码框样式 */
.code-inputs {
  width: 100%;
  justify-content: space-around;
  padding: 0 20rpx;
  position: relative;
}

.code-cell {
  width: 80rpx;
  height: 100rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  position: relative;
  background: rgba(255, 255, 255, 0.02);
}

.code-cell.active {
  border-color: var(--theme-color-blue);
  box-shadow: 0 0 15rpx rgba(0, 180, 216, 0.3);
}

.code-char {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 闪烁光标 */
.cursor-bar {
  width: 4rpx;
  height: 48rpx;
  background-color: var(--theme-color-blue);
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.hidden-input {
  position: absolute;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}
