/* 战绩大厅样式表 */

.profile-page {
  padding-bottom: 80rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
}

/* 个人名片 */
.user-badge-card {
  margin-top: 15rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(0, 150, 199, 0.06) 0%, rgba(11, 155, 119, 0.04) 100%);
  border: 1px solid rgba(0, 150, 199, 0.12);
  display: flex;
  flex-direction: column;
}

.user-card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

.user-avatar-box {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(0, 150, 199, 0.25);
  background-color: rgba(0, 0, 0, 0.02);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 40rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #1e2a27;
}

.user-register-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.user-total-score {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.total-score-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.total-score-value {
  font-size: 38rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.score-green {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(6, 214, 160, 0.15);
}

.score-red {
  color: #ff6b6b;
  text-shadow: 0 0 10rpx rgba(255, 107, 107, 0.15);
}

.card-divider {
  height: 1px;
  background: rgba(0, 150, 199, 0.08);
  width: 100%;
  margin: 24rpx 0 20rpx 0;
}

.user-card-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  padding: 0 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
}

.text-green {
  color: var(--theme-color-green);
}

.text-red {
  color: #ff6b6b;
}

.text-blue {
  color: var(--theme-color-blue);
}

/* Tab 切换栏 */
.tab-header {
  margin: 10rpx 30rpx 30rpx;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.tab-item.active {
  background: rgba(0, 150, 199, 0.08);
  color: var(--theme-color-blue);
  border: 1px solid rgba(0, 150, 199, 0.15);
  font-weight: bold;
}

/* 历史卡片详情 */
.history-card {
  margin-bottom: 24rpx;
  margin-top: 24rpx;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.room-code-tag {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
}

.room-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.room-players-list {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  max-width: 480rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-row-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.card-row-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.final-score-title {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.score-container {
  display: flex;
  align-items: center;
}

.final-score-num {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
}

.tea-pool-report {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.play-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 战友榜单样式 */
.friend-stat-card {
  margin-bottom: 24rpx;
  padding: 30rpx 24rpx 30rpx;
}

/* 战友排行榜绝对序号样式 */
.friend-rank-box {
  width: 50rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.friend-rank-num {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.friend-rank-num.rank-1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(255, 165, 0, 0.3);
}

.friend-rank-num.rank-2 {
  background: linear-gradient(135deg, #e0e0e0 0%, #b0b0b0 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(176, 176, 176, 0.35);
}

.friend-rank-num.rank-3 {
  background: linear-gradient(135deg, #e8a87c 0%, #c38d9e 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(195, 141, 158, 0.3);
}

.friend-rank-num.rank-other {
  color: var(--text-secondary, #809a96);
  background: transparent;
}

.friend-avatar-box {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(11, 155, 119, 0.25);
  background-color: rgba(0, 0, 0, 0.02);
  margin-right: 24rpx;
}

.friend-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.friend-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 36rpx;
  font-weight: bold;
}

.friend-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
}

.friend-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.outcome-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  text-align: right;
}

.outcome-score {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 12rpx;
  text-align: right;
}

/* 统一分数配色 */
.score-positive {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(6, 214, 160, 0.2);
}

.score-negative {
  color: #ff6b6b;
  text-shadow: 0 0 10rpx rgba(255, 107, 107, 0.2);
}

.score-zero {
  color: #ffffff;
}

/* 空状态占位 */
.empty-state {
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 房间状态标签 */
.room-status-badge {
  font-size: 20rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  margin-left: 14rpx;
  font-weight: bold;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  height: 36rpx; /* 强制锁定精致扁平 tag 的物理高度 */
  box-sizing: border-box;
}

.status-ongoing {
  background-color: rgba(255, 193, 7, 0.15);
  color: #ffc107;
}

.status-finished {
  background-color: rgba(40, 167, 69, 0.15);
  color: #28a745;
}

/* 我自己的专属高亮样式 */
.friend-stat-card.friend-me {
  border: 1.5px solid rgba(11, 155, 119, 0.5) !important;
  box-shadow: 0 6rpx 20rpx rgba(11, 155, 119, 0.18) !important;
  background: rgba(11, 155, 119, 0.1) !important; /* 增加绿色背景深度，提升区分度 */
}

/* 头像上方浮动的小黄标 “我” */
.me-badge {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ffd700;
  color: #5c4308;
  font-size: 16rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  z-index: 10;
  box-shadow: 0 2rpx 6rpx rgba(255, 215, 0, 0.3);
  white-space: nowrap;
}

/* 房间状态后过期的内联文字提示 */
.expire-tip-inline {
  font-size: 20rpx;
  color: #ff6b6b;
  margin-left: 14rpx;
  font-weight: bold;
}