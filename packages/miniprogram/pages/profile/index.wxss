/* 战绩大厅样式表 */

.profile-page {
  padding-bottom: 80rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
}

/* 个人名片 */
.user-badge-card {
  margin-top: 15rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(0, 150, 199, 0.06) 0%, rgba(11, 155, 119, 0.04) 100%);
  border: 1px solid rgba(0, 150, 199, 0.12);
  display: flex;
  flex-direction: column;
}

.user-card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

.user-avatar-box {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(0, 150, 199, 0.25);
  background-color: rgba(0, 0, 0, 0.02);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 40rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #1e2a27;
}

.user-register-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.user-total-score {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.total-score-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.total-score-value {
  font-size: 38rpx;
  font-weight: bold;
}

.score-green {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(6, 214, 160, 0.15);
}

.score-red {
  color: #ff6b6b;
  text-shadow: 0 0 10rpx rgba(255, 107, 107, 0.15);
}

.card-divider {
  height: 1px;
  background: rgba(0, 150, 199, 0.08);
  width: 100%;
  margin: 24rpx 0 20rpx 0;
}

.user-card-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  padding: 0 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
}

.text-green {
  color: var(--theme-color-green);
}

.text-red {
  color: #ff6b6b;
}

.text-blue {
  color: var(--theme-color-blue);
}

/* Tab 切换栏 */
.tab-header {
  margin: 10rpx 30rpx 30rpx;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.tab-item.active {
  background: rgba(0, 150, 199, 0.08);
  color: var(--theme-color-blue);
  border: 1px solid rgba(0, 150, 199, 0.15);
  font-weight: bold;
}

/* 历史卡片详情 */
.history-card {
  margin-bottom: 24rpx;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.room-code-tag {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
}

.room-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.final-score-title {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.final-score-num {
  font-size: 40rpx;
  font-weight: bold;
}

.tea-pool-report {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.play-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 战友榜单样式 */
.friend-stat-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.friend-avatar-box {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(11, 155, 119, 0.25);
  background-color: rgba(0, 0, 0, 0.02);
  margin-right: 24rpx;
}

.friend-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.friend-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 36rpx;
  font-weight: bold;
}

.friend-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
}

.friend-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.outcome-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.outcome-score {
  font-size: 36rpx;
  font-weight: bold;
}

/* 统一分数配色 */
.score-positive {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(6, 214, 160, 0.2);
}

.score-negative {
  color: #ff6b6b;
  text-shadow: 0 0 10rpx rgba(255, 107, 107, 0.2);
}

.score-zero {
  color: #ffffff;
}

/* 空状态占位 */
.empty-state {
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
