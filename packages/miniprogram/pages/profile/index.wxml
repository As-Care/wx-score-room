<view class="page-container profile-page">
  <!-- 自定义高端导航栏 -->
  <view class="custom-navbar" style="height: {{statusBarHeight + navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="navbar-back flex-center" bindtap="goBack">
      <van-icon name="arrow-left" color="#1e2a27" size="18px" />
    </view>
    <view class="navbar-title">📊 战绩中心</view>
  </view>

  <view class="content-wrapper" style="padding-top: {{statusBarHeight + navBarHeight + 10}}px;">
    
    <!-- 个人名片 -->
    <view class="glass-card user-badge-card flex-column">
      <!-- 上半部分：头像、名字和总积分 -->
      <view class="user-card-top flex-row align-center width-100">
        <view class="user-avatar-box flex-center">
          <image class="user-avatar" src="{{userInfo.avatar_url}}" mode="aspectFill" wx:if="{{userInfo.avatar_url}}"></image>
          <view class="user-avatar-text flex-center" wx:else>{{userInfo.nickname[0] || '?'}}</view>
        </view>
        <view class="user-info flex-column flex-1">
          <text class="user-nickname">{{userInfo.nickname || '未登录'}}</text>
          <text class="user-register-time">打牌记账专属游戏玩家</text>
        </view>
        <view class="user-total-score flex-column align-end">
          <text class="total-score-label">历史总积分</text>
          <text class="total-score-desc">(仅计算已结束对局)</text>
          <text class="total-score-value {{totalScore >= 0 ? 'score-red' : 'score-green'}}">{{totalScore >= 0 ? '+' : ''}}{{totalScore}}</text>
        </view>
      </view>

      <!-- 下半部分分割线 -->
      <view class="card-divider"></view>

      <!-- 下半部分：赢输胜率统计 -->
      <view class="user-card-bottom flex-row justify-between width-100">
        <view class="stat-item">
          <text class="stat-label">总</text>
          <text class="stat-value text-blue">{{totalGames}} 局</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">赢</text>
          <text class="stat-value text-red">{{wins}} 局</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">输</text>
          <text class="stat-value text-green">{{losses}} 局</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">胜率</text>
          <text class="stat-value text-blue">{{winRate}}%</text>
        </view>
      </view>
    </view>

    <!-- Tab 切换 (历史对局 / 亲友战友) -->
    <view class="tab-header flex-row">
      <view class="tab-item {{activeTab === 0 ? 'active' : ''}} flex-center" bindtap="switchTab" data-index="{{0}}">
        <van-icon name="clock-o" size="16px" style="margin-right: 8rpx;" />
        <text>对局历史</text>
      </view>
      <view class="tab-item {{activeTab === 1 ? 'active' : ''}} flex-center" bindtap="switchTab" data-index="{{1}}">
        <van-icon name="friends-o" size="16px" style="margin-right: 8rpx;" />
        <text>我的战友</text>
        <van-icon name="down" size="12px" style="margin-left: 8rpx; transition: transform 0.2s; transform: rotate({{sortAscending ? 180 : 0}}deg);" wx:if="{{activeTab === 1}}" />
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="tab-content">
      
      <!-- 1. 历史对局列表 -->
      <view class="history-list-view" wx:if="{{activeTab === 0}}">
        <view class="glass-card history-card" wx:for="{{historyRooms}}" wx:key="room_id" bindtap="goToRoom" data-room-id="{{item.room_id}}" data-room-code="{{item.room_code}}" data-room-status="{{item.room_status}}">
          <!-- 第一排：房间号 与 最终得分标签 -->
          <view class="card-row-top justify-between align-center">
            <view class="flex-row align-center">
              <text class="room-code-tag">房间: {{item.room_code}}</text>
              <view class="room-status-badge {{item.room_status === 1 ? 'status-finished' : 'status-ongoing'}}">
                {{item.room_status === 1 ? '已结束' : '进行中'}}
              </view>
              <text class="expire-tip-inline" wx:if="{{item.expire_minutes > 0}}">{{item.expire_minutes}}分钟后过期</text>
            </view>
            <text class="final-score-title">最终得分</text>
          </view>
          
          <!-- 第二排：(房主/玩家) 与 (最终分值) -->
          <view class="card-row-bottom justify-between align-center" style="margin-top: 16rpx;">
            <!-- 左侧：房主、玩家列 -->
            <view class="flex-column" style="flex: 1; min-width: 0; padding-right: 30rpx;">
              <text class="room-meta">房主: {{item.owner_nickname}}</text>
              <text class="room-players-list ellipsis">玩家: {{item.player_names || ''}}</text>
            </view>
            <!-- 右侧：分值大数字 (垂直居中对齐左侧两行文字) -->
            <view class="score-container">
              <text class="final-score-num {{item.final_score > 0 ? 'score-positive' : (item.final_score < 0 ? 'score-negative' : 'score-zero')}}">{{item.final_score > 0 ? '+' + item.final_score : item.final_score}}</text>
            </view>
          </view>
          
          <view class="history-footer justify-between align-center" style="padding-top: 20rpx; border-top: 1px solid rgba(255, 255, 255, 0.03);">
            <text class="tea-pool-report" wx:if="{{item.accumulated_tea_money > 0}}">🍵 本局茶水: {{item.accumulated_tea_money}} 分</text>
            <text class="tea-pool-report" wx:else>🍵 无茶水设置</text>
            <text class="play-date">{{item.created_at}}</text>
          </view>
        </view>
        
        <!-- 分页底部加载提示 -->
        <view class="load-more-section flex-center" wx:if="{{historyRooms.length > 0}}" style="padding: 30rpx 0; margin-bottom: 20rpx;">
          <view class="load-loading flex-row align-center flex-center" wx:if="{{isLoading}}">
            <van-loading size="16px" type="spinner" color="#0b9b77" custom-class="loading-spin" />
            <text class="load-text" style="font-size: 24rpx; color: #809a96; margin-left: 12rpx;">正在加载更多对局...</text>
          </view>
          <view class="load-nomore flex-center" wx:elif="{{!hasMore}}">
            <text class="load-nomore-text" style="font-size: 22rpx; color: #b2c4c1; letter-spacing: 2rpx;">— 已加载全部历史对局 —</text>
          </view>
        </view>
        
        <view class="empty-state flex-column flex-center" wx:if="{{historyRooms.length === 0}}">
          <van-loading size="48px" type="spinner" color="#0b9b77" wx:if="{{isLoading}}" />
          <van-icon name="todo-list-o" size="48px" color="#809a96" wx:else />
          <text class="empty-text">{{isLoading ? '正在加载，请稍后...' : '你还没有参与过任何游戏对局'}}</text>
        </view>
      </view>

      <!-- 2. 战友榜列表 -->
      <view class="friends-list-view" wx:if="{{activeTab === 1}}">
        <view class="glass-card friend-stat-card flex-row align-center {{item.isMe ? 'friend-me' : ''}}" wx:for="{{friendsList}}" wx:key="friend_id">
          <!-- 绝对排行序号 -->
          <view class="friend-rank-box flex-center">
            <view class="friend-rank-num {{item.rank === 1 ? 'rank-1' : (item.rank === 2 ? 'rank-2' : (item.rank === 3 ? 'rank-3' : 'rank-other'))}}">
              {{item.rank}}
            </view>
          </view>

          <view class="avatar-container-wrap" style="position: relative; margin-right: 24rpx;">
            <view class="friend-avatar-box flex-center" style="margin-right: 0;">
              <image class="friend-avatar" src="{{item.avatar_url}}" mode="aspectFill" wx:if="{{item.avatar_url}}"></image>
              <view class="friend-avatar-text flex-center" wx:else>{{item.nickname[0] || '?'}}</view>
            </view>
            <view class="me-badge" wx:if="{{item.isMe}}">我</view>
          </view>

          <view class="friend-main-info flex-1 flex-column">
            <text class="friend-name">{{item.nickname}}</text>
            <text class="friend-count" wx:if="{{!item.isMe}}">共同对局 {{item.play_count}} 次</text>
          </view>

          <view class="friend-outcome-box flex-column align-end">
            <text class="outcome-label">{{item.isMe ? '胜负累计' : '同场胜负累计'}}</text>
            <text class="outcome-score {{item.net_score > 0 ? 'score-positive' : (item.net_score < 0 ? 'score-negative' : 'score-zero')}}" decode="{{true}}">{{item.net_score > 0 ? '+' + item.net_score : item.net_score}}&nbsp;分</text>
          </view>
        </view>

        <view class="empty-state flex-column flex-center" wx:if="{{friendsList.length === 0}}">
          <van-loading size="48px" type="spinner" color="#0b9b77" wx:if="{{isLoading}}" />
          <van-icon name="cluster-o" size="48px" color="#809a96" wx:else />
          <text class="empty-text">{{isLoading ? '正在加载，请稍后...' : '暂无一起游戏过的亲友，快去邀请他们吧'}}</text>
        </view>
      </view>

    </view>
  </view>
</view>
