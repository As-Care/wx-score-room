/* 房间页样式表 */

.room-page {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  flex: 1; /* 吃满除导航栏外的全部垂直高度 */
  min-height: 0; /* 防止子元素内容溢出撑爆布局 */
  box-sizing: border-box;
}

/* 头部状态卡片 */
.room-header-card {
  margin-top: 15rpx;
  position: relative;
}

.card-section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tea-stats {
  display: flex;
  align-items: baseline;
}

.tea-current {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--theme-color-green);
  text-shadow: 0 0 20rpx rgba(6, 214, 160, 0.4);
}

.tea-slash {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin: 0 10rpx;
}

.tea-total {
  font-size: 30rpx;
  color: #1e2a27;
}

/* 发光进度条 */
.tea-progress-wrapper {
  width: 100%;
  height: 12rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  margin-top: 30rpx;
  position: relative;
  overflow: hidden;
}

.tea-progress-bar {
  height: 100%;
  background: linear-gradient(
    90deg,
    var(--theme-color-blue) 0%,
    var(--theme-color-green) 100%
  );
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

.tea-progress-glow {
  position: absolute;
  top: 0;
  height: 100%;
  background: linear-gradient(
    90deg,
    var(--theme-color-blue) 0%,
    var(--theme-color-green) 100%
  );
  filter: blur(4px);
  opacity: 0.6;
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

/* 茶水钱满额徽章 */
.tea-completed-badge {
  background: rgba(11, 155, 119, 0.08);
  border: 1px solid rgba(11, 155, 119, 0.25);
  color: var(--theme-color-green);
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx;
  border-radius: 12rpx;
  margin-top: 24rpx;
  box-shadow: 0 0 15rpx rgba(11, 155, 119, 0.05);
}

/* 邀请与分享按钮栏 */
.room-action-bar {
  margin: 0 30rpx 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  color: #ffffff;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.btn-blue-shadow {
  background: linear-gradient(135deg, #0077b6 0%, #0096c7 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 150, 199, 0.15);
}

.btn-green-shadow {
  background: linear-gradient(135deg, #0b9b77 0%, #06d6a0 100%);
  box-shadow: 0 8rpx 20rpx rgba(11, 155, 119, 0.15);
}

/* 玩家列表排版区 */
.players-section {
  margin: 20rpx 30rpx 0;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
  display: inline-flex;
  align-items: center;
}

.section-icon {
  margin-right: 8rpx;
  line-height: 1;
  position: relative;
  top: -4rpx; /* 微调上移 4rpx，完美解决系统 Emoji 的物理偏斜问题 */
}

.section-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 横向滚动列表容器 (添加 padding-bottom 留出阴影渲染空间，消除切阴影黑线) */
.players-scroll-container {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.players-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap; /* 强行单行排布 */
  width: 100%;
  box-sizing: border-box;
  gap: 12rpx; /* 卡片之间的间距 */
  padding: 6rpx 4rpx 8rpx 4rpx; /* 没有阴影后，底部内边距收紧为 8rpx，使整体更紧凑 */
}

/* 统一玩家卡片样式 (设定基础样式，去除阴影，应用轻盈微边框) */
.player-card {
  flex: 0 0 calc((100% - 48rpx) / 5); /* 默认 5 个以上时固定为 20% 宽度 */
  margin: 0 !important;
  padding: 16rpx 4rpx !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
  min-width: 0;
  box-shadow: none !important; /* 彻底去除用户卡片阴影效果 */
  border: 1px solid rgba(11, 40, 34, 0.07) !important; /* 精致淡色实体描边，代替投影界定边缘 */
}

/* 1和2个人的时候宽度为 33% (平分 3 等分) */
.players-count-1 .player-card,
.players-count-2 .player-card {
  flex: 0 0 calc((100% - 24rpx) / 3);
}

/* 3个人的时候宽度为等分 (3 等分) */
.players-count-3 .player-card {
  flex: 0 0 calc((100% - 24rpx) / 3);
}

/* 4个人的时候宽度为等分 (4 等分) */
.players-count-4 .player-card {
  flex: 0 0 calc((100% - 36rpx) / 4);
}

/* 5个人的时候宽度为等分 (5 等分) */
.players-count-5 .player-card {
  flex: 0 0 calc((100% - 48rpx) / 5);
}

/* 头像外层独立的 container */
.player-avatar-container {
  position: relative;
  margin-bottom: 8rpx;
  margin-top: 6rpx;
}

/* 通用头像及文字代用头像 (尺寸整体变小至 80rpx * 80rpx) */
.player-avatar-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(0, 0, 0, 0.02);
  border: 2px solid rgba(0, 150, 199, 0.25);
  transition: all 0.2s ease;
}

/* 在线状态指示小圆点 */
.status-dot {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  z-index: 5;
  transition: all 0.2s ease;
}

.status-dot.online {
  background-color: #28a745;
  box-shadow: 0 0 6rpx rgba(40, 167, 69, 0.6);
}

.status-dot.offline {
  background-color: #abb8c3;
}

/* 在线和离线的头像边框阴影 */
.player-avatar-box.avatar-online {
  border-color: rgba(40, 167, 69, 0.4) !important;
  box-shadow: 0 4rpx 10rpx rgba(40, 167, 69, 0.25) !important;
}

.player-avatar-box.avatar-offline {
  border-color: rgba(171, 184, 195, 0.4) !important;
  box-shadow: 0 4rpx 10rpx rgba(171, 184, 195, 0.2) !important;
}

.player-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.player-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 26rpx; /* 文字代用头像字体略微收小 */
  font-weight: bold;
}

.player-info-box {
  width: 100%;
  align-items: center;
}

.player-nickname {
  font-size: 24rpx; /* 昵称字体稍微收小，防止在一行折行 */
  color: #1e2a27;
  font-weight: bold;
  max-width: 95%;
  line-height: 32rpx;
  margin-bottom: 4rpx;
}

.player-score {
  font-weight: bold;
  font-size: 28rpx; /* 分数数值字体微调为 28rpx，防止大位数溢出 */
  line-height: 34rpx;
  margin-top: 6rpx;
}

.score-positive {
  color: #d90429;
  text-shadow: 0 0 10rpx rgba(217, 4, 41, 0.1);
}

.score-negative {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(11, 155, 119, 0.1);
}

.score-zero {
  color: #1e2a27;
}

/* 对账流水账 (占用页面剩余空间，并在小屏上撑开最小高度) */
.tx-history-card {
  padding: 30rpx 30rpx 10rpx 30rpx;
  flex: 1; /* 自动撑满剩余高度 */
  display: flex;
  flex-direction: column;
  min-height: 520rpx; /* 卡片整体最小高度为 520rpx，适配极小屏手机 */
  box-sizing: border-box;
  margin-bottom: 24rpx !important;
}

.tx-list {
  display: flex;
  flex-direction: column;
  flex: 1; /* 列表占据卡片内部剩余全部高度 */
  min-height: 0; /* 允许高度在 flex 内收缩以正常唤起滚动条 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.tx-item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 0;
}

.tx-item:last-child {
  border-bottom: none;
}

.tx-flow {
  font-size: 28rpx;
  color: #1e2a27;
}

.tx-arrow {
  color: var(--text-secondary);
  margin: 0 10rpx;
  font-size: 22rpx;
}

.text-green-glow {
  color: var(--theme-color-green);
  font-weight: bold;
}

.tx-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.tx-amount {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--theme-color-blue);
}

.tx-tea-detail {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.tx-right-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 15rpx;
}

.tx-undo-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(217, 4, 41, 0.06);
  border: 1px solid rgba(217, 4, 41, 0.15);
}

.tx-undo-btn:active {
  background: rgba(217, 4, 41, 0.12);
}

.tx-empty {
  padding: 40rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 二维码弹窗 */
.qr-popup-content {
  background-color: #ffffff;
}

.qr-code-img {
  width: 320rpx;
  height: 320rpx;
  margin: 40rpx 0;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  background-color: #ffffff;
}

.room-code-display {
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  width: 90%;
  padding: 24rpx;
}

.code-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.code-number {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--theme-color-blue);
  letter-spacing: 4rpx;
  margin-top: 6rpx;
  text-shadow: 0 0 15rpx rgba(0, 150, 199, 0.15);
}

.copy-tip {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 记分弹窗中的付分人单选滑动框 */
.selection-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 15rpx;
}

.payers-scroll {
  white-space: nowrap;
  width: 100%;
}

.payer-option-card {
  display: inline-flex;
  min-width: 140rpx;
  height: 70rpx;
  padding: 0 24rpx;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.payer-option-card.active {
  background: rgba(0, 150, 199, 0.06);
  border-color: var(--theme-color-blue);
  color: var(--theme-color-blue);
  box-shadow: 0 0 10rpx rgba(0, 150, 199, 0.1);
}

.payer-opt-name {
  font-size: 26rpx;
  max-width: 120rpx;
  font-weight: 500;
}

/* 茶水钱开关行 */
.tea-switch-row {
  margin-top: 30rpx;
  background-color: rgba(0, 0, 0, 0.01);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
}

.switch-title {
  font-size: 28rpx;
  color: #1e2a27;
  font-weight: 500;
}

.switch-desc {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 结算弹窗 (白金微光渐变，尊贵感设计) */
.crown-box {
  font-size: 80rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
  margin-bottom: 10rpx;
}

.settle-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #1e2a27;
  letter-spacing: 2rpx;
}

.mvp-box {
  margin: 20rpx auto 0 auto;
  position: relative;
  background: rgba(11, 155, 119, 0.03);
  border: 1px solid rgba(11, 155, 119, 0.15);
  border-radius: 30rpx;
  padding: 20rpx;
  width: 54%;
  box-shadow: 0 8rpx 30rpx rgba(11, 155, 119, 0.05);
  box-sizing: border-box;
}

.mvp-avatar-box {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 4rpx solid #ffd700;
  box-shadow: 0 0 25rpx rgba(255, 215, 0, 0.2);
  position: relative;
}

.mvp-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.mvp-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #fdf6d0 0%, #ffd700 100%);
  color: #5c4308;
  font-size: 32rpx;
  font-weight: bold;
}

.mvp-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ffd700;
  color: #5c4308;
  font-size: 16rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.mvp-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #1e2a27;
  margin-top: 14rpx;
}

.mvp-score {
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 4rpx;
}

/* 排行榜单项 */
.rank-item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 10rpx;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-number {
  font-size: 26rpx;
  font-weight: bold;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background-color: rgba(0, 0, 0, 0.04);
  color: var(--text-secondary);
}

.rank-number.first {
  background-color: #ffd700;
  color: #5c4308;
}

.rank-number.second {
  background-color: #c0c0c0;
  color: #2b2b2b;
}

.rank-number.third {
  background-color: #cd7f32;
  color: #ffffff;
}

.rank-name {
  font-size: 28rpx;
  color: #1e2a27;
  max-width: 260rpx;
  font-weight: 500;
}

.rank-score {
  font-size: 28rpx;
  font-weight: bold;
}

.settle-tea-summary {
  margin-top: 30rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  padding: 16rpx 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 头像上方浮动的小黄标 “我” */
.me-badge {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ffd700;
  color: #5c4308;
  font-size: 16rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  z-index: 10;
  box-shadow: 0 2rpx 6rpx rgba(255, 215, 0, 0.3);
  white-space: nowrap;
}

/* 弹窗副标题-我的分数提示 */
.popup-subtitle-score {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
  font-weight: 500;
}

/* 手动刷新分数按钮 */
.refresh-action {
  background: rgba(11, 155, 119, 0.08);
  border: 1px solid rgba(11, 155, 119, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.refresh-action:active {
  background: rgba(11, 155, 119, 0.15);
  opacity: 0.8;
}

.refresh-icon-container {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
  line-height: 1;
}

.refresh-text {
  font-size: 20rpx;
  color: var(--theme-color-green);
  font-weight: 500;
  line-height: 1;
}

/* 刷新旋转动效 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.spinning {
  animation: spin 0.8s linear infinite;
}

/* 房间内修改头像和昵称组件样式 */
.room-profile-setup {
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
}

.room-avatar-wrapper {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 0 20rpx 0;
  border: 3rpx solid rgba(0, 150, 199, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 150, 199, 0.08);
  position: relative;
  overflow: hidden;
  background-color: transparent !important;
}

.room-avatar-wrapper::after {
  border: none;
}

.room-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.room-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  border-radius: 50%;
}

.room-placeholder-text {
  font-size: 18rpx;
  color: var(--theme-color-green);
  margin-top: 6rpx;
  font-weight: 600;
}

.room-avatar-hover-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  font-size: 16rpx;
}

.room-nickname-input {
  width: 60%;
  height: 70rpx;
  min-height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e2a27;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  padding: 0;
  margin-bottom: 20rpx;
}

.room-nickname-input:focus {
  border-bottom: 2rpx solid var(--theme-color-blue);
}

.btn-green-save {
  background: linear-gradient(135deg, #0b9b77 0%, #06d6a0 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 4rpx 10rpx rgba(11, 155, 119, 0.15) !important;
  border-radius: 12rpx !important;
  font-weight: bold !important;
  font-size: 24rpx !important;
  height: 60rpx !important;
  line-height: 58rpx !important;
  width: 220rpx !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 撤销样式 */
.tx-item {
  position: relative; /* 必须是 relative，好让 mask 能绝对定位覆盖它 */
}

.undone-item {
  opacity: 0.55; /* 弱化视觉 */
}

.tx-undone-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.35);
  z-index: 5;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 12rpx;
  pointer-events: auto; /* 拦截所有点击事件，不让子元素产生点击 */
}

.tx-undone-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #d90429;
  border: 2rpx dashed #d90429;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.9);
  transform: rotate(-7deg); /* 倾斜盖章效果 */
}

/* 昵称特别着色 */
.my-name {
  color: var(--theme-color-green) !important;
  font-weight: bold;
}

/* 茶水设置方式选择器 */
.tea-mode-tabs {
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
  padding: 4rpx;
}

.tea-mode-tab {
  font-size: 24rpx;
  color: #809a96;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  transition: all 0.2s ease;
}

.tea-mode-tab.active {
  background-color: #ffffff;
  color: var(--theme-color-green);
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.tea-mode-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
  font-weight: 500;
}

/* 对账单 Tab 选择器与支出收入着色 */
.bill-header-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.bill-tabs {
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
  padding: 4rpx;
  display: flex;
  flex-direction: row;
}

.bill-tab {
  font-size: 22rpx;
  color: #809a96;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  transition: all 0.2s ease;
}

.bill-tab.active {
  background-color: #ffffff;
  color: var(--theme-color-green);
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.tx-amount-expense {
  color: var(--theme-color-green) !important; /* 绿色支出 */
  font-weight: bold;
}

.tx-amount-income {
  color: #ee0a24 !important; /* 红色收入 */
  font-weight: bold;
}

.full-page-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #edf2f0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* 快捷分值标签样式 */
.quick-scores-container {
  width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.quick-scores-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
}

.quick-score-tag {
  flex: 1;
  margin: 0 8rpx;
  height: 60rpx;
  background: #f1f5f3;
  color: #596c68;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: all 0.15s ease;
}

.quick-score-tag.active {
  background: rgba(11, 155, 119, 0.1);
  color: #0b9b77;
  border-color: rgba(11, 155, 119, 0.2);
  font-weight: bold;
}

/* 极简结算方案样式 */
.settle-scheme-box {
  background: rgba(11, 155, 119, 0.04);
  border: 1rpx solid rgba(11, 155, 119, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.scheme-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #0b9b77;
  margin-bottom: 16rpx;
}

.scheme-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.scheme-item {
  font-size: 24rpx;
  color: #2c3e50;
  background: rgba(255, 255, 255, 0.6);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.scheme-name {
  max-width: 150rpx;
  font-weight: 500;
}

.from-name {
  color: var(--theme-color-green); /* 绿色付款人 */
}

.to-name {
  color: #d90429; /* 红色收款人 */
}

.scheme-arrow {
  margin: 0 16rpx;
  color: #95a5a6;
  font-weight: bold;
}

.scheme-amount {
  font-weight: bold;
  color: #2c3e50;
}

/* 已结束房间整体高度自适应 */
.room-page.room-page-scrollable {
  height: auto;
  min-height: 100vh;
  overflow-y: auto;
}

.room-page-scrollable .content-wrapper {
  flex: none;
  min-height: auto;
}

.room-page-scrollable .tx-history-card {
  flex: none;
  min-height: auto;
}

.room-page-scrollable .tx-list {
  max-height: 80vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  flex: none;
}

/* 局势走势图样式及手风琴动画 */
.trend-chart-card {
  padding: 30rpx !important;
  margin-bottom: 24rpx !important;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.trend-chart-header {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.toggle-icon {
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.toggle-icon.rotate {
  transform: rotate(180deg);
}

.trend-chart-body-wrapper {
  height: 0;
  opacity: 0;
  overflow: hidden;
  transition: height 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.25s ease, margin-top 0.3s ease;
  margin-top: 0;
}

.trend-chart-card.expanded .trend-chart-body-wrapper {
  height: 520rpx; /* ECharts 容器的 520rpx 高度 */
  opacity: 1;
  margin-top: 25rpx;
}

#trendChartDom {
  width: 100%;
  height: 100%;
  display: block;
}

/* 茶水金库结算对象选择面板 */
.tea-recipient-selector-panel {
  background: rgba(11, 155, 119, 0.03);
  border: 1px dashed rgba(11, 155, 119, 0.2);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.selector-title {
  font-size: 22rpx;
  color: #809a96;
  margin-bottom: 18rpx;
  text-align: center;
  font-weight: 500;
}

.tag-scroll-row {
  width: 100%;
  white-space: nowrap;
}

.tag-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 0;
}

.tag-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1px solid rgba(0, 0, 0, 0.08);
  color: #596c68;
  white-space: nowrap;
  transition: all 0.2s ease-in-out;
}

.tag-btn.active {
  background: #0b9b77;
  border-color: #0b9b77;
  color: #ffffff;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(11, 155, 119, 0.2);
}
