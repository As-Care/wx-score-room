/* 房间页样式表 */

.room-page {
  padding-bottom: 60rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
}

/* 头部状态卡片 */
.room-header-card {
  margin-top: 15rpx;
  position: relative;
}

.card-section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tea-stats {
  display: flex;
  align-items: baseline;
}

.tea-current {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--theme-color-green);
  text-shadow: 0 0 20rpx rgba(6, 214, 160, 0.4);
}

.tea-slash {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin: 0 10rpx;
}

.tea-total {
  font-size: 30rpx;
  color: #1e2a27;
}

/* 发光进度条 */
.tea-progress-wrapper {
  width: 100%;
  height: 12rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  margin-top: 30rpx;
  position: relative;
  overflow: hidden;
}

.tea-progress-bar {
  height: 100%;
  background: linear-gradient(
    90deg,
    var(--theme-color-blue) 0%,
    var(--theme-color-green) 100%
  );
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

.tea-progress-glow {
  position: absolute;
  top: 0;
  height: 100%;
  background: linear-gradient(
    90deg,
    var(--theme-color-blue) 0%,
    var(--theme-color-green) 100%
  );
  filter: blur(4px);
  opacity: 0.6;
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

/* 茶水钱满额徽章 */
.tea-completed-badge {
  background: rgba(11, 155, 119, 0.08);
  border: 1px solid rgba(11, 155, 119, 0.25);
  color: var(--theme-color-green);
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx;
  border-radius: 12rpx;
  margin-top: 24rpx;
  box-shadow: 0 0 15rpx rgba(11, 155, 119, 0.05);
}

/* 邀请与分享按钮栏 */
.room-action-bar {
  margin: 0 30rpx 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  color: #ffffff;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.btn-blue-shadow {
  background: linear-gradient(135deg, #0077b6 0%, #0096c7 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 150, 199, 0.15);
}

.btn-green-shadow {
  background: linear-gradient(135deg, #0b9b77 0%, #06d6a0 100%);
  box-shadow: 0 8rpx 20rpx rgba(11, 155, 119, 0.15);
}

/* 玩家列表排版区 */
.players-section {
  margin: 20rpx 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
  display: inline-flex;
  align-items: center;
}

.section-icon {
  margin-right: 8rpx;
  line-height: 1;
  position: relative;
  top: -4rpx; /* 微调上移 4rpx，完美解决系统 Emoji 的物理偏斜问题 */
}

.section-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 统一的网格大卡片容器 */
.players-grid-container {
  display: grid;
  gap: 20rpx;
}

/* 1/2/4人 一排2个 */
.grid-cols-2 {
  grid-template-columns: 1fr 1fr;
}

/* 3人及大于4人 一排3个 */
.grid-cols-3 {
  grid-template-columns: 1fr 1fr 1fr;
}

/* 统一玩家卡片样式 */
.player-card {
  margin: 0 !important;
  padding: 24rpx 12rpx !important; /* 压缩内边距以保障在一行3个时文字不挤压折行 */
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* 头像外层独立的 container，用来在头像外面正上方绝对定位【我】字 */
.player-avatar-container {
  position: relative;
  margin-bottom: 12rpx;
  margin-top: 12rpx;
}

/* 通用头像及文字代用头像 */
.player-avatar-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(0, 0, 0, 0.02);
  border: 2px solid rgba(0, 150, 199, 0.25);
}

.player-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.player-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  color: var(--theme-color-green);
  font-size: 32rpx;
  font-weight: bold;
}

.player-info-box {
  width: 100%;
  align-items: center;
}

.player-nickname {
  font-size: 28rpx;
  color: #1e2a27;
  font-weight: bold;
  max-width: 100%;
  line-height: 36rpx; /* 精细设定行高，消除文字默认多余的上下空距 */
  margin-bottom: 6rpx; /* 代替多余的空行，提供优雅的 6rpx 紧凑间隙 */
}

.player-score {
  font-weight: bold;
  font-size: 34rpx;
  line-height: 40rpx; /* 精细设定行高，消除多余空距 */
  margin-top: 8rpx;
}

.score-positive {
  color: var(--theme-color-green);
  text-shadow: 0 0 10rpx rgba(11, 155, 119, 0.1);
}

.score-negative {
  color: #d90429;
  text-shadow: 0 0 10rpx rgba(217, 4, 41, 0.1);
}

.score-zero {
  color: #1e2a27;
}

/* 对账流水账 */
.tx-history-card {
  padding: 30rpx;
}

.tx-list {
  display: flex;
  flex-direction: column;
  max-height: 480rpx;
  overflow-y: auto;
}

.tx-item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 0;
}

.tx-item:last-child {
  border-bottom: none;
}

.tx-flow {
  font-size: 28rpx;
  color: #1e2a27;
}

.tx-arrow {
  color: var(--text-secondary);
  margin: 0 10rpx;
  font-size: 22rpx;
}

.text-green-glow {
  color: var(--theme-color-green);
  font-weight: bold;
}

.tx-time {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.tx-amount {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--theme-color-blue);
}

.tx-tea-detail {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.tx-right-box {
  gap: 15rpx;
}

.tx-undo-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(217, 4, 41, 0.06);
  border: 1px solid rgba(217, 4, 41, 0.15);
}

.tx-undo-btn:active {
  background: rgba(217, 4, 41, 0.12);
}

.tx-empty {
  padding: 40rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 二维码弹窗 */
.qr-popup-content {
  background-color: #ffffff;
}

.qr-code-img {
  width: 320rpx;
  height: 320rpx;
  margin: 40rpx 0;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  background-color: #ffffff;
}

.room-code-display {
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  width: 90%;
  padding: 24rpx;
}

.code-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.code-number {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--theme-color-blue);
  letter-spacing: 4rpx;
  margin-top: 6rpx;
  text-shadow: 0 0 15rpx rgba(0, 150, 199, 0.15);
}

.copy-tip {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 记分弹窗中的付分人单选滑动框 */
.selection-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 15rpx;
}

.payers-scroll {
  white-space: nowrap;
  width: 100%;
}

.payer-option-card {
  display: inline-flex;
  min-width: 140rpx;
  height: 70rpx;
  padding: 0 24rpx;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.payer-option-card.active {
  background: rgba(0, 150, 199, 0.06);
  border-color: var(--theme-color-blue);
  color: var(--theme-color-blue);
  box-shadow: 0 0 10rpx rgba(0, 150, 199, 0.1);
}

.payer-opt-name {
  font-size: 26rpx;
  max-width: 120rpx;
  font-weight: 500;
}

/* 茶水钱开关行 */
.tea-switch-row {
  margin-top: 30rpx;
  background-color: rgba(0, 0, 0, 0.01);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
}

.switch-title {
  font-size: 28rpx;
  color: #1e2a27;
  font-weight: 500;
}

.switch-desc {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 结算弹窗 (白金微光渐变，尊贵感设计) */
.crown-box {
  font-size: 80rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
  margin-bottom: 10rpx;
}

.settle-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #1e2a27;
  letter-spacing: 2rpx;
}

.mvp-box {
  margin-top: 30rpx;
  position: relative;
  background: rgba(11, 155, 119, 0.03);
  border: 1px solid rgba(11, 155, 119, 0.15);
  border-radius: 30rpx;
  padding: 30rpx;
  width: 70%;
  box-shadow: 0 8rpx 30rpx rgba(11, 155, 119, 0.05);
}

.mvp-avatar-box {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 4rpx solid #ffd700;
  box-shadow: 0 0 25rpx rgba(255, 215, 0, 0.2);
  position: relative;
}

.mvp-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.mvp-avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #fdf6d0 0%, #ffd700 100%);
  color: #5c4308;
  font-size: 40rpx;
  font-weight: bold;
}

.mvp-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ffd700;
  color: #5c4308;
  font-size: 18rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.mvp-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e2a27;
  margin-top: 24rpx;
}

.mvp-score {
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 6rpx;
}

/* 排行榜单项 */
.rank-item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 10rpx;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-number {
  font-size: 26rpx;
  font-weight: bold;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background-color: rgba(0, 0, 0, 0.04);
  color: var(--text-secondary);
}

.rank-number.first {
  background-color: #ffd700;
  color: #5c4308;
}

.rank-number.second {
  background-color: #c0c0c0;
  color: #2b2b2b;
}

.rank-number.third {
  background-color: #cd7f32;
  color: #ffffff;
}

.rank-name {
  font-size: 28rpx;
  color: #1e2a27;
  max-width: 260rpx;
  font-weight: 500;
}

.rank-score {
  font-size: 28rpx;
  font-weight: bold;
}

.settle-tea-summary {
  margin-top: 30rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  padding: 16rpx 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 头像上方浮动的小黄标 “我” */
.me-badge {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #ffd700;
  color: #5c4308;
  font-size: 16rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  z-index: 10;
  box-shadow: 0 2rpx 6rpx rgba(255, 215, 0, 0.3);
  white-space: nowrap;
}

/* 弹窗副标题-我的分数提示 */
.popup-subtitle-score {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
  font-weight: 500;
}

/* 手动刷新分数按钮 */
.refresh-action {
  background: rgba(11, 155, 119, 0.08);
  border: 1px solid rgba(11, 155, 119, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.refresh-action:active {
  background: rgba(11, 155, 119, 0.15);
  opacity: 0.8;
}

.refresh-icon-container {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
  line-height: 1;
  position: relative;
  top: 2rpx; /* 精密下偏 2rpx，完美解决 Vant 字体图标和文字基线视差问题 */
}

.refresh-text {
  font-size: 20rpx;
  color: var(--theme-color-green);
  font-weight: 500;
  line-height: 1;
}

/* 刷新旋转动效 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.spinning {
  animation: spin 0.8s linear infinite;
}

/* 房间内修改头像和昵称组件样式 */
.room-profile-setup {
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
}

.room-avatar-wrapper {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 0 20rpx 0;
  border: 3rpx solid rgba(0, 150, 199, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 150, 199, 0.08);
  position: relative;
  overflow: hidden;
  background-color: transparent !important;
}

.room-avatar-wrapper::after {
  border: none;
}

.room-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.room-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e6f2f0 0%, #b2ebd8 100%);
  border-radius: 50%;
}

.room-placeholder-text {
  font-size: 18rpx;
  color: var(--theme-color-green);
  margin-top: 6rpx;
  font-weight: 600;
}

.room-avatar-hover-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  font-size: 16rpx;
}

.room-nickname-input {
  width: 60%;
  height: 70rpx;
  min-height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e2a27;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.1);
  padding: 0;
  margin-bottom: 20rpx;
}

.room-nickname-input:focus {
  border-bottom: 2rpx solid var(--theme-color-blue);
}

.btn-green-save {
  background: linear-gradient(135deg, #0b9b77 0%, #06d6a0 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 4rpx 10rpx rgba(11, 155, 119, 0.15) !important;
  border-radius: 12rpx !important;
  font-weight: bold !important;
  font-size: 24rpx !important;
  height: 60rpx !important;
  line-height: 58rpx !important;
  width: 220rpx !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 撤销样式 */
.tx-item {
  position: relative; /* 必须是 relative，好让 mask 能绝对定位覆盖它 */
}

.undone-item {
  opacity: 0.55; /* 弱化视觉 */
}

.tx-undone-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.35);
  z-index: 5;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 12rpx;
  pointer-events: auto; /* 拦截所有点击事件，不让子元素产生点击 */
}

.tx-undone-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #d90429;
  border: 2rpx dashed #d90429;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.9);
  transform: rotate(-7deg); /* 倾斜盖章效果 */
}

/* 昵称特别着色 */
.my-name {
  color: var(--theme-color-green) !important;
  font-weight: bold;
}

/* 茶水设置方式选择器 */
.tea-mode-tabs {
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
  padding: 4rpx;
}

.tea-mode-tab {
  font-size: 24rpx;
  color: #809a96;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  transition: all 0.2s ease;
}

.tea-mode-tab.active {
  background-color: #ffffff;
  color: var(--theme-color-green);
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.tea-mode-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
  font-weight: 500;
}

/* 对账单 Tab 选择器与支出收入着色 */
.bill-header-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.bill-tabs {
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
  padding: 4rpx;
  display: flex;
  flex-direction: row;
}

.bill-tab {
  font-size: 22rpx;
  color: #809a96;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  transition: all 0.2s ease;
}

.bill-tab.active {
  background-color: #ffffff;
  color: var(--theme-color-green);
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.tx-amount-expense {
  color: #ee0a24 !important; /* 红色支出 */
  font-weight: bold;
}

.tx-amount-income {
  color: #0096c7 !important; /* 蓝色收入 */
  font-weight: bold;
}
